{
  "name": "file-recovery-pro",
  "version": "3.0.5",
  "description": "FileRecoveryPro - Professional File Recovery with Performance Optimizations + USB Support",
  "main": "electron/main.js",
  "author": "Xaicon-coder",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "cleanup:win": "scripts\\cleanup-windows.bat",
    "cleanup:win:ps": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-windows.ps1"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.filerecoverypro.app",
    "productName": "File Recovery Pro",
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "owner": "Xaicon-coder",
        "repo": "file-recovery-pro"
      }
    ],
    "files": [
      "dist/**",
      "electron/**",
      "!electron/**/*.backup",
      "!electron/**/*.old",
      "node_modules/electron-updater/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "File Recovery Pro",
      "deleteAppDataOnUninstall": true
    },
    "portable": {
      "artifactName": "${productName}_v${version}_Portable.exe"
    },
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "artifactName": "${productName}_v${version}_Setup.exe"
  },
  "homepage": "https://github.com/Xaicon-coder/file-recovery-pro"
}